# Local development — use same-origin /api (proxied to the API by next.config rewrites).
# Direct http://localhost:4000/api breaks session cookies across ports.
NEXT_PUBLIC_OPSWATCH_API_URL="/api"
# Upstream API target for the /api proxy route handler.
OPSWATCH_API_ORIGIN="http://127.0.0.1:4000"

# Production (Vercel API project — set in Vercel web project env)
# NEXT_PUBLIC_OPSWATCH_API_URL="https://opswatch-api.vercel.app/api"
