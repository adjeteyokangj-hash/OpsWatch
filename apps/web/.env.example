# Local development — browser calls same-origin /api.
# Split local `pnpm dev` (API on :4000): keep OPSWATCH_API_ORIGIN below.
# Production (Vercel): API runs in-process — OPSWATCH_API_ORIGIN is ignored unless
# OPSWATCH_EMBEDDED_API=false (legacy two-project proxy). Prefer removing the origin.
NEXT_PUBLIC_OPSWATCH_API_URL="/api"
OPSWATCH_API_ORIGIN="http://127.0.0.1:4000"
# OPSWATCH_EMBEDDED_API="true"

# Unified production: copy apps/api secrets onto this Vercel web project
# (DATABASE_URL, JWT_SECRET, PLATFORM_SUPER_ADMIN_EMAILS, STRIPE_*, etc.).
# Platform Super Admin is email allowlist only — not creatable in Members UI.