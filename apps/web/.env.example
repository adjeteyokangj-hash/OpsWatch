# Local development — browser calls same-origin /api (proxied to the API).
NEXT_PUBLIC_OPSWATCH_API_URL="/api"
# Upstream API target for the /api proxy route handler (preferred in production).
OPSWATCH_API_ORIGIN="http://127.0.0.1:4000"

# Production (Vercel web project — set at least one upstream variable)
# OPSWATCH_API_ORIGIN="https://opswatch-api.vercel.app"
# Legacy (still supported): derive upstream from the absolute public API URL
# NEXT_PUBLIC_OPSWATCH_API_URL="https://opswatch-api.vercel.app/api"
