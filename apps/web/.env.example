# Local development — browser calls same-origin /api.
# Split dev (pnpm dev runs API on :4000): keep OPSWATCH_API_ORIGIN below.
# Production unified deploy (Noble model): remove OPSWATCH_API_ORIGIN — API runs in-process.
NEXT_PUBLIC_OPSWATCH_API_URL="/api"
OPSWATCH_API_ORIGIN="http://127.0.0.1:4000"

# Unified production: copy all apps/api/.env.example vars onto this Vercel web project.
# DATABASE_URL, JWT_SECRET, PLATFORM_SUPER_ADMIN_EMAILS, STRIPE_*, etc.
