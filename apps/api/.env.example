NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opswatch?schema=public"
# Runtime (Vercel): Supabase Transaction pooler on port 6543 — must include pgbouncer=true
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations (local/CI): Supabase Session pooler on port 5432 — use for DIRECT_URL and one-off migrate
# DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/opswatch?schema=public"
JWT_SECRET="opswatch-local-jwt-2026-live-a9f31d2c"

OPSWATCH_WEB_URL="http://localhost:3000"
# Optional: share session cookies across API/web subdomains in production (default derives from OPSWATCH_WEB_URL)
# OPSWATCH_COOKIE_DOMAIN=".okanggroup.com"

ALERT_FROM_EMAIL=""
ALERT_TO_EMAIL=""

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="alerts@opswatch.app"

# Ingest signing (required when INGEST_SIGNING_REQUIRED=true, the default)
INGEST_SIGNING_REQUIRED="true"
INGEST_TIMESTAMP_WINDOW_SECONDS="300"

# Server-managed browser sessions (default: enabled). Set false only for local bearer-token testing.
SESSION_SIGNING_REQUIRED="true"
SESSION_ABSOLUTE_TTL_SECONDS="43200"
SESSION_IDLE_TTL_SECONDS="1800"
SESSION_IDLE_TOUCH_INTERVAL_SECONDS="60"

# Required for inbound provider webhooks (fail-closed: unset secrets reject with 503)
VERCEL_WEBHOOK_SECRET=""
GITHUB_WEBHOOK_SECRET=""
RENDER_WEBHOOK_SECRET=""

# Stripe billing — platform singleton (Super Admin: /admin/billing/stripe)
# Leave empty to disable checkout/portal/webhooks; endpoints return 503.
# Platform DB settings take precedence; env vars are deployment fallback.
OPSWATCH_SECRETS_ENCRYPTION_KEY=""
PLATFORM_SUPER_ADMIN_EMAILS="admin@okanggroup.com"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
# Per-plan Stripe Price IDs — sync with: pnpm billing:sync-prices
STRIPE_PRICE_PILOT_MONTHLY=""
STRIPE_PRICE_PILOT_ANNUAL=""
STRIPE_PRICE_GROWTH_MONTHLY=""
STRIPE_PRICE_GROWTH_ANNUAL=""
STRIPE_PRICE_BUSINESS_MONTHLY=""
STRIPE_PRICE_BUSINESS_ANNUAL=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_ANNUAL=""

# Optional thresholds
EVENT_SPIKE_WINDOW_MINUTES="5"
AUTH_FAILURE_SPIKE_THRESHOLD="10"
TRAFFIC_SPIKE_THRESHOLD="50"

# Optional remediation toggles/endpoints
AUTO_REMEDIATION_ENABLED="true"
REMEDIATION_MAX_AUTO_RETRIES="3"
REMEDIATION_RETRY_BASE_DELAY_MS="5000"
WORKER_RESTART_WEBHOOK_URL=""
SERVICE_RESTART_WEBHOOK_URL=""
DEPLOYMENT_ROLLBACK_WEBHOOK_URL=""
PAYMENT_VERIFICATION_ENDPOINT=""
JOB_REQUEUE_ENDPOINT=""
PROVIDER_STATUS_URL=""
RUNBOOK_BASE_URL=""

# Deep analysis + autonomous healing
# Production default: keep disabled until explicitly enabled per org/action.
AUTO_HEAL_DEFAULT_ENABLED="false"
AUTO_HEAL_ACK_FIRST="false"
AUTO_RUN_MIN_CONFIDENCE_SCORE="70"
AUTO_HEAL_SWEEP_LIMIT="10"
REMEDIATION_LOCK_TTL_MS="120000"
WORKER_INTERNAL_SECRET="opswatch-local-worker-secret"
PLATFORM_PLAYBOOK_APPROVER_EMAILS=""
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# OpsWatch self-monitoring (four-layer)
OPSWATCH_SELF_MONITOR_SLUG="opswatch-production"
OPSWATCH_SELF_MONITOR_ORG_SLUG="opswatch-default"
OPSWATCH_WEB_HEALTH_URL="http://localhost:3000/login"
OPSWATCH_WEB_LOGIN_URL="http://localhost:3000/login"
OPSWATCH_API_LIVE_URL="http://127.0.0.1:4000/api/health/live"
OPSWATCH_API_READY_URL="http://127.0.0.1:4000/api/health/ready"
# Independent external monitor (UptimeRobot, Better Stack, or deployed web URL)
EXTERNAL_UPTIME_CHECK_URL="https://ops-watch-web.vercel.app/login"
OPSWATCH_NOTIFICATION_PROBE_URL=""
OPSWATCH_WEBHOOK_PROBE_URL=""
INCIDENT_AI_LLM_ENABLED="false"
INCIDENT_AI_LLM_MODEL="gpt-4o-mini"
INCIDENT_AI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_API_KEY=""

# Adaptive topology — learned / observation-driven relationship auto-create stays OFF by default.
# Manual admin propose-learned always creates PENDING LEARNED edges; approval is still required.
OPSWATCH_LEARNED_TOPOLOGY_ENABLED="false"

# Intelligence / AI Brain — predictions stay OFF until explicitly enabled.
# Even when true, product emission still requires MIN_PREDICTION_CONFIDENCE + evidence.
OPSWATCH_PREDICTIONS_ENABLED="false"
OPSWATCH_MIN_DISPLAY_CONFIDENCE="0.7"
OPSWATCH_MIN_RECOMMENDATION_CONFIDENCE="0.6"
OPSWATCH_MIN_PREDICTION_CONFIDENCE="0.85"
OPSWATCH_MIN_BASELINE_SAMPLES="5"

# Automation AI (Phase 3)
AUTOMATION_LLM_PLANNER_ENABLED="false"
AUTOMATION_RATE_PLANS_PER_ORG_HOUR="30"
AUTOMATION_RATE_RUNS_PER_PLAYBOOK_HOUR="10"
AUTOMATION_RATE_REMEDIATIONS_PER_INCIDENT_HOUR="5"
AUTOMATION_RATE_REMEDIATIONS_PER_SERVICE_15MIN="3"
AUTOMATION_AUTONOMOUS_SWEEP_LIMIT="10"
CIRCUIT_RESTART_SERVICE="3,15"
CIRCUIT_RESTART_WORKER="3,15"
CIRCUIT_REQUEUE_JOB="5,15"
CIRCUIT_AUTOMATION_RUN="5,60"
