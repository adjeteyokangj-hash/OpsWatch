{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "express",
  "installCommand": "cd ../.. && pnpm install --prod=false",
  "buildCommand": "cd ../.. && pnpm --filter @opswatch/api vercel-build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ]
}
