  Project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  SLODefinition   SLODefinition @relation(fields: [sloDefinitionId], references: [id], onDelete: Cascade)

  @@unique([sloDefinitionId, windowStart, windowEnd])
  @@index([projectId, windowEnd])
  @@index([status, windowEnd])
}

model StatusPage {
  id             String       @id
  organizationId String
  projectId      String?
  title          String
  slug           String       @unique
  description    String?
  isPublic       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project        Project?     @relation(fields: [projectId], references: [id])
}

model User {
  id             String        @id
  name           String
  email          String        @unique
  passwordHash   String
  role           String        @default("MEMBER")
  isActive       Boolean       @default(true)
  // isPlatformSuperAdmin added by migration 20260714060000; accessed via platform-super-admin-column.ts
  // so Prisma does not SELECT a missing column before migrate deploy.
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  organizationId String?
  Alert          Alert[]
  AuditLog       AuditLog[]
  Organization   Organization? @relation(fields: [organizationId], references: [id])
  UserSession    UserSession[]
  OwnedServices  Service[]            @relation("ServiceOwner")
  OwnedEntities  OperationalEntity[]  @relation("OperationalEntityOwner")

  @@index([organizationId])
}

model UserSession {
  id            String    @id
  userId        String
  tokenHash     String    @unique
  csrfTokenHash String
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  expiresAt     DateTime
  idleExpiresAt DateTime
  revokedAt     DateTime?
  revokedReason String?
  ipAddress     String?
  userAgent     String?
