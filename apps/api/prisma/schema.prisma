  stripeSubscriptionId String?
  stripePriceId        String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  Organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Plan                 Plan               @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model UsageRecord {
  id             String       @id
  organizationId String
  metricKey      String
  quantity       Int
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, metricKey, periodStart])
}

model IncidentMemoryEntry {
  id                   String       @id
  organizationId       String
  incidentId           String       @unique
  projectId            String?
  title                String
  category             String?
  diagnosisSummary     String
  /// Only populated when root cause was recorded/known — never invented.
  rootCause            String?
  resolutionSummary    String?
  signatureText        String
  embeddingJson        Json?
  timelineJson         Json?
  affectedServiceIds   Json?
  affectedModuleKeys   Json?
  affectedWorkflowKeys Json?
  recoveryActionsJson  Json?
  automationInvolved   Boolean      @default(false)
  verificationSummary  String?
  resolutionTimeMs     Int?
  resolvedAt           DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime
  Organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, resolvedAt])
  @@index([organizationId, projectId])
}

/// Continuous AI Brain observation of operational signals (facts only).
model OperationalObservation {
  id             String       @id
  organizationId String
  projectId      String?
  sourceType     String
  sourceId       String?
  eventKey       String
  summary        String
  severity       String?
  payloadJson    Json?
  observedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, observedAt])
  @@index([organizationId, sourceType, observedAt])
  @@index([projectId, observedAt])
  @@index([organizationId, eventKey, observedAt])
}

/// Accumulated evidence baselines (nothing without samples).
model LearningBaseline {
  id             String       @id
  organizationId String
  /// Empty string = org-scoped baseline (avoids NULL uniqueness holes in Postgres).
  projectId      String       @default("")
  scopeType      String
  scopeKey       String
  sampleCount    Int          @default(0)
  metricsJson    Json
  lastSampleAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId, scopeType, scopeKey])
  @@index([organizationId, scopeType])
}

/// Stored patterns; displayEligible stays false until confidence threshold is met.
model OperationalPattern {
  id              String       @id
  organizationId  String
  projectId       String?
  patternType     String
  signatureKey    String
  title           String
  description     String
  evidenceCount   Int          @default(0)
  confidenceScore Float        @default(0)
  evidenceJson    Json?
  lastMatchedAt   DateTime?
  displayEligible Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime
  Organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, patternType, signatureKey])
  @@index([organizationId, displayEligible, confidenceScore])
  @@index([organizationId, patternType])
}

/// Evidence-based confidence scores — no recommendation without confidence.
model AiConfidenceRecord {
  id                 String       @id
  organizationId     String
  subjectType        String
  subjectId          String
  score              Float
  label              String
  evidenceCount      Int          @default(0)
  historicalAccuracy Float?
  matchingIncidents  Int          @default(0)
  recoveryMatches    Int          @default(0)
  dataCompleteness   Float        @default(0)
  factorsJson        Json?
  computedAt         DateTime     @default(now())
  Organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, subjectType, subjectId])
  @@index([organizationId, computedAt])
}

/// Prediction framework storage — product emission gated OFF by default.
model PredictionCandidate {
  id              String       @id
  organizationId  String
  projectId       String?
  predictionType  String
  title           String
  summary         String
  confidenceScore Float        @default(0)
  /// DISABLED | INSUFFICIENT_DATA | READY — READY only when predictions feature flag is on AND threshold met.
  status          String       @default("DISABLED")
  evidenceJson    Json?
  computedAt      DateTime     @default(now())
  expiresAt       DateTime?
  Organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, computedAt])
  @@index([organizationId, predictionType])
}

/// Empty until predictions are enabled and outcomes can be scored.
model PredictionAccuracyLog {
  id               String       @id
  organizationId   String
  predictionId     String?
  predictedOutcome String
  actualOutcome    String?
  wasCorrect       Boolean?
  recordedAt       DateTime     @default(now())
  Organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, recordedAt])
}

/// Org-level chronological factual operations timeline.
model OperationsTimelineEvent {
  id             String       @id
  organizationId String
  projectId      String?
  eventType      String
  summary        String
  sourceType     String?
  sourceId       String?
  severity       String?
  payloadJson    Json?
  occurredAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([organizationId, eventType, occurredAt])
}

/// Deployment intelligence for correlation (facts from change events / webhooks).
