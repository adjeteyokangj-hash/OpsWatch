  resultingIncidentIds Json?
  resultingAlertIds    Json?
  recoveryEventIds     Json?
  changeEventId        String?
  source               String       @default("CHANGE_EVENT")
  summary              String
  detailsJson          Json?
  createdAt            DateTime     @default(now())
  Organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, deployedAt])
  @@index([projectId, deployedAt])
  @@index([changeEventId])
}

/// Audit trail for AI decisions and recovery actions.
model AiDecisionAudit {
