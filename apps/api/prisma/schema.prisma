  organizationId  String
  actorUserId     String?
  decisionType    String
  subjectType     String
  subjectId       String?
  summary         String
  confidenceScore Float?
  evidenceJson    Json?
  outcome         String?
  createdAt       DateTime     @default(now())
  Organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, decisionType, createdAt])
}

/// Per-application learning model state (storage only; predictions still gated).
