  @@index([projectId, enabled])
  @@index([projectId, archivedAt])
  @@index([serviceId, enabled])
}

model SLOWindow {
  id              String        @id
  sloDefinitionId String
  projectId       String
  windowStart     DateTime
  windowEnd       DateTime
  windowMinutes   Int
  availabilityPct Float?
  errorRatePct    Float?
  p95LatencyMs    Int?
  burnRate        Float?
