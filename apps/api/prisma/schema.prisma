generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Alert {
  id               String          @id
  projectId        String
  serviceId        String?
  sourceType       String
  sourceId         String?
  severity         AlertSeverity
  title            String
  message          String
  status           AlertStatus     @default(OPEN)
  firstSeenAt      DateTime        @default(now())
  lastSeenAt       DateTime        @default(now())
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  assignedToUserId String?
  category         AlertCategory   @default(AVAILABILITY)
  integrationId    String?
  maintenanceSuppressed Boolean    @default(false)
  maintenanceWindowId String?
  User             User?           @relation(fields: [assignedToUserId], references: [id])
  Project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Service          Service?        @relation(fields: [serviceId], references: [id])
  IncidentAlert    IncidentAlert[]
}

model AuditLog {
  id           String   @id
  userId       String?
  action       String
  entityType   String
  entityId     String
  metadataJson Json?
  createdAt    DateTime @default(now())
  User         User?    @relation(fields: [userId], references: [id])
}

model AutoRemediationPolicy {
  id             String   @id
  organizationId String
  policyType     String
  policyKey      String
  enabled        Boolean  @default(false)
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@unique([organizationId, policyType, policyKey])
  @@index([organizationId])
}

model Check {
  id                 String        @id
  serviceId          String
  name               String
  type               CheckType
  intervalSeconds    Int
  timeoutMs          Int
  expectedStatusCode Int?
  expectedKeyword    String?
  failureThreshold   Int           @default(3)
  recoveryThreshold  Int           @default(2)
  configJson         Json?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime
  Service            Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  CheckResult        CheckResult[]
}

model CheckResult {
  id             String      @id
  checkId        String
  status         CheckStatus
  responseCode   Int?
  responseTimeMs Int?
  message        String?
  rawJson        Json?
  checkedAt      DateTime    @default(now())
  Check          Check       @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([checkId, checkedAt])
}

model Event {
  id          String        @id
  projectId   String
  serviceId   String?
  type        EventType
  severity    AlertSeverity
  source      String
  message     String
  fingerprint String?
  payloadJson Json?
  createdAt   DateTime      @default(now())
  Project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Service     Service?      @relation(fields: [serviceId], references: [id])

  @@index([projectId, createdAt])
}

model Heartbeat {
  id          String   @id
  projectId   String
  environment String
  appVersion  String?
  commitSha   String?
  status      String
  message     String?
  payloadJson Json?
  receivedAt  DateTime @default(now())
  Project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, receivedAt])
}

model Incident {
  id                   String          @id
  projectId            String
  correlationGroupId   String?
  title                String
  severity             AlertSeverity
  status               IncidentStatus  @default(OPEN)
  openedAt             DateTime        @default(now())
  acknowledgedAt       DateTime?
  resolvedAt           DateTime?
  rootCause            String?
  resolutionNotes      String?
  ChangeEvent          ChangeEvent[]
  IncidentTimelineEvent IncidentTimelineEvent[]
  Project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  IncidentAlert        IncidentAlert[]
  CorrelationGroup     OrganizationIncidentGroup? @relation(fields: [correlationGroupId], references: [id], onDelete: SetNull)

  @@index([projectId, openedAt])
  @@index([correlationGroupId])
}

model IncidentAlert {
  incidentId String
  alertId    String
  Alert      Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  Incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@id([incidentId, alertId])
}

model NotificationChannel {
  id        String   @id
  type      String
  name      String
  target    String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  projectId String?
  updatedAt DateTime
  Project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, isActive])
}

model OnboardingProgress {
  id             String       @id
  organizationId String       @unique
  completedSteps String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrgApiKey {
  id                String       @id
  organizationId    String
  name              String
  keyId             String       @unique
  secretHash        String
  scopes            Json
  environment       String
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime     @default(now())
  projectId         String?
  revokedAt         DateTime?
  lastUsedRoute     String?
  lastUsedIp        String?
  lastUsedUserAgent String?
  revokeReason      String?
  Organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, revokedAt])
  @@index([projectId])
}

model Organization {
  id                 String              @id
  name               String
  slug               String              @unique
  plan               BillingPlan         @default(FREE)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  OnboardingProgress OnboardingProgress?
  OrgApiKey          OrgApiKey[]
  Project            Project[]
  StatusPage         StatusPage[]
  User               User[]
  IncidentGroups     OrganizationIncidentGroup[]
  MaintenanceWindows MaintenanceWindow[]
  Subscription       Subscription?
  UsageRecord        UsageRecord[]
  IncidentMemoryEntry IncidentMemoryEntry[]
}

model OrganizationIncidentGroup {
  id                 String   @id
  organizationId     String
  correlationKey     String
  rootCauseSummary   String?
  primaryIncidentId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  Organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Incidents          Incident[]

  @@index([organizationId, correlationKey])
  @@index([organizationId, createdAt])
}

model Project {
  id                  String                @id
  name                String
  slug                String                @unique
  clientName          String
  description         String?
  environment         String
  status              ProjectStatus         @default(UNKNOWN)
  healthReason        String?
  healthSource        String?
  lastCompletedCheckAt DateTime?
  lastSignalAt        DateTime?
  monitoringEnabled   Boolean               @default(true)
  monitoringStartedAt DateTime?
  automationMode      String                @default("OBSERVE")
  projectOwner        String?
  operationalContact  String?
  defaultRegion       String?
  frontendUrl         String?
  backendUrl          String?
  repoUrl             String?
  vercelProjectId     String?
  renderServiceId     String?
  apiKey              String                @unique
  signingSecret       String
  maintenanceTier     String?
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  organizationId      String?
  Alert               Alert[]
  ChangeEvent         ChangeEvent[]
  Event               Event[]
  Heartbeat           Heartbeat[]
  Incident            Incident[]
  IncidentTimelineEvent IncidentTimelineEvent[]
  NotificationChannel NotificationChannel[]
  Organization        Organization?         @relation(fields: [organizationId], references: [id])
  ProjectIntegration  ProjectIntegration[]
  ServiceDependency   ServiceDependency[]
  Service             Service[]
  SLODefinition       SLODefinition[]
  SLOWindow           SLOWindow[]
  StatusPage          StatusPage[]
  MaintenanceWindows  MaintenanceWindow[]
  ProjectBilling      ProjectBilling?

  @@index([organizationId])
}

model ProjectIntegration {
  id                String                      @id
  projectId         String
  type              IntegrationType
  name              String?
  enabled           Boolean                     @default(true)
  configJson        Json?
  secretRef         String?
  validationStatus  IntegrationValidationStatus @default(UNKNOWN)
  validationMessage String?
  lastValidatedAt   DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime
  Project           Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([projectId, enabled])
}

model RemediationLog {
  id                  String            @id
  organizationId      String
  alertId             String?
  incidentId          String?
  action              String
  contextJson         Json?
  executedBy          String?
  status              RemediationStatus @default(PENDING_APPROVAL)
  resultJson          Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime
  approvedBy          String?
  executedAt          DateTime?
  projectId           String?
  serviceId           String?
  impactTier          String?
  predictedLabel      String?
  predictedScore      Int?
  executionMode       String            @default("MANUAL")
  policySnapshot      Json?
  suppressionSnapshot Json?
  idempotencyKey      String?

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, action, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, executionMode, createdAt])
  @@index([incidentId, status, createdAt])
}

model RemediationLock {
  id             String   @id
  lockKey        String   @unique
  organizationId String
  incidentId     String?
  action         String?
  holder         String
  acquiredAt     DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
  @@index([organizationId, incidentId])
}

model AutomationPlaybook {
  id          String   @id
  key         String   @unique
  name        String
  description String
  riskLevel   String   @default("LOW")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Versions    AutomationPlaybookVersion[]
}

model AutomationPlaybookVersion {
  id             String   @id
  playbookId     String
  version        Int
  definitionJson Json?
  status         AutomationPlaybookVersionStatus @default(DRAFT)
  submittedById  String?
  submittedAt    DateTime?
  reviewedById   String?
  reviewedAt     DateTime?
  reviewReason   String?
  approvedAt     DateTime?
  deprecatedAt   DateTime?
  publishedAt    DateTime @default(now())
  publishedBy    String?
  Playbook       AutomationPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  Steps          AutomationPlaybookStep[]
  Runs           AutomationRun[]

  @@unique([playbookId, version])
  @@index([playbookId, status])
}

model AutomationPlaybookStep {
  id                 String @id
  versionId          String
  stepOrder          Int
  action             String
  targetServiceKey   String?
  approvalRequired   Boolean @default(false)
  description        String
  Version            AutomationPlaybookVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, stepOrder])
}

model AutomationRun {
  id                 String   @id
  organizationId     String
  projectId          String
  incidentId         String
  versionId          String
  approvedVersionId  String?
  executionMode      String   @default("OBSERVE")
  status             String   @default("PLANNED")
  planJson           Json
  analysisMode       String?
  confidence         Float?
  riskLevel          String?
  reason             String?
  createdBy          String?
  approvedBy         String?
  approvedAt         DateTime?
  cancelledBy        String?
  cancelledAt        DateTime?
  currentStepOrder   Int?
  supersededByRunId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  Version            AutomationPlaybookVersion @relation(fields: [versionId], references: [id])
  Steps              AutomationRunStep[]
  Approvals          AutomationApproval[]
  Outcomes           AutomationOutcome[]

  @@index([organizationId, incidentId, createdAt])
  @@index([projectId, status])
}

model AutomationRunStep {
  id                 String @id
  runId              String
  stepOrder          Int
  action             String
  targetServiceId    String?
  approvalRequired   Boolean @default(false)
  status             String  @default("PENDING")
  remediationLogId   String?
  resultJson         Json?
  Run                AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepOrder])
}

model AutomationApproval {
  id         String   @id
  runId      String
  approvedBy String?
  reason     String
  decision   String
  scope      String   @default("RUN")
  createdAt  DateTime @default(now())
  Run        AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AutomationPolicy {
  id             String   @id
  organizationId String
  policyKey      String
  enabled        Boolean  @default(false)
  executionMode  String   @default("OBSERVE")
  updatedBy      String?
  updatedAt      DateTime
  createdAt      DateTime @default(now())

  @@unique([organizationId, policyKey])
}

model AutomationOutcome {
  id          String   @id
  runId       String
  summary     String
  success     Boolean
  detailsJson Json?
  createdAt   DateTime @default(now())
  Run         AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Service {
  id         String        @id
  projectId  String
  name       String
  type       ServiceType
  status     ProjectStatus @default(UNKNOWN)
  criticality String       @default("MEDIUM")
  baseUrl    String?
  isCritical Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime
  Alert      Alert[]
  Check      Check[]
  ChangeEvent ChangeEvent[]
  Event      Event[]
  IncomingDependencies ServiceDependency[] @relation("DependencyToService")
  OutgoingDependencies ServiceDependency[] @relation("DependencyFromService")
  Project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  SLODefinition SLODefinition[]
  MaintenanceWindowServices MaintenanceWindowService[]
}

model ChangeEvent {
  id             String   @id
  organizationId String
  projectId      String?
  serviceId      String?
  incidentId     String?
  eventType      String
  actor          String?
  summary        String
  detailsJson    Json?
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  Incident       Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  Project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  Service        Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([serviceId, occurredAt])
  @@index([incidentId, occurredAt])
}

model ServiceDependency {
  id             String   @id
  projectId      String
  fromServiceId  String
  toServiceId    String
  dependencyType String   @default("RUNTIME")
  criticality    String   @default("HIGH")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  FromService    Service  @relation("DependencyFromService", fields: [fromServiceId], references: [id], onDelete: Cascade)
  Project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ToService      Service  @relation("DependencyToService", fields: [toServiceId], references: [id], onDelete: Cascade)

  @@unique([fromServiceId, toServiceId, dependencyType])
  @@index([projectId, isActive])
  @@index([fromServiceId])
  @@index([toServiceId])
}

model IncidentTimelineEvent {
  id         String        @id
  incidentId String
  projectId  String
  eventType  String
  summary    String
  sourceType String?
  sourceId   String?
  severity   AlertSeverity?
  payloadJson Json?
  occurredAt DateTime      @default(now())
  createdAt  DateTime      @default(now())
  Incident   Incident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  Project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([incidentId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([sourceType, sourceId])
}

model SLODefinition {
  id                 String    @id
  projectId          String
  serviceId          String?
  targetType         String    @default("SERVICE")
  targetId           String?
  name               String
  sliType            String
  targetPct          Float
  windowDays         Int       @default(30)
  windowType         String    @default("ROLLING")
  latencyThresholdMs Int?
  enabled            Boolean   @default(true)
  archivedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  Project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Service            Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  SLOWindow          SLOWindow[]

  @@index([projectId, enabled])
  @@index([projectId, archivedAt])
  @@index([serviceId, enabled])
}

model SLOWindow {
  id              String        @id
  sloDefinitionId String
  projectId       String
  windowStart     DateTime
  windowEnd       DateTime
  windowMinutes   Int
  availabilityPct Float?
  errorRatePct    Float?
  p95LatencyMs    Int?
  burnRate        Float?
  status          String        @default("HEALTHY")
  createdAt       DateTime      @default(now())
  Project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  SLODefinition   SLODefinition @relation(fields: [sloDefinitionId], references: [id], onDelete: Cascade)

  @@unique([sloDefinitionId, windowStart, windowEnd])
  @@index([projectId, windowEnd])
  @@index([status, windowEnd])
}

model StatusPage {
  id             String       @id
  organizationId String
  projectId      String?
  title          String
  slug           String       @unique
  description    String?
  isPublic       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project        Project?     @relation(fields: [projectId], references: [id])
}

model User {
  id             String        @id
  name           String
  email          String        @unique
  passwordHash   String
  role           String        @default("MEMBER")
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  organizationId String?
  Alert          Alert[]
  AuditLog       AuditLog[]
  Organization   Organization? @relation(fields: [organizationId], references: [id])
  UserSession    UserSession[]

  @@index([organizationId])
}

model UserSession {
  id            String    @id
  userId        String
  tokenHash     String    @unique
  csrfTokenHash String
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  expiresAt     DateTime
  idleExpiresAt DateTime
  revokedAt     DateTime?
  revokedReason String?
  ipAddress     String?
  userAgent     String?
  User          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([idleExpiresAt])
}

model CoverageTarget {
  id             String   @id
  projectId      String
  targetType     String
  targetKey      String
  label          String
  criticality    String   @default("HIGH")
  isCovered      Boolean  @default(false)
  coverageSource String?
  detailsJson    Json?
  updatedAt      DateTime @default(now())

  @@unique([projectId, targetKey])
  @@index([projectId, isCovered])
}

model InsightActionRun {
  id                      String    @id
  projectId               String
  insightRecommendationId String?
  actionType              String
  status                  String    @default("PENDING")
  requestedById           String?
  approvedById            String?
  resultJson              Json?
  errorMessage            String?
  createdAt               DateTime  @default(now())
  completedAt             DateTime?

  @@index([insightRecommendationId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, status])
}

model InsightRecommendation {
  id          String    @id
  projectId   String
  type        String
  title       String
  description String
  priority    Int       @default(50)
  riskLevel   String    @default("MEDIUM")
  actionLevel String    @default("MANUAL_APPLY")
  payloadJson Json?
  status      String    @default("OPEN")
  source      String    @default("COVERAGE")
  createdAt   DateTime  @default(now())
  appliedAt   DateTime?
  dismissedAt DateTime?

  @@index([projectId, source])
  @@index([projectId, status])
}

model MonitoringProfile {
  id             String   @id
  key            String   @unique
  name           String
  providerType   String
  description    String
  definitionJson Json
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model SyntheticJourney {
  id             String    @id
  projectId      String
  name           String
  type           String    @default("BROWSER")
  status         String    @default("DRAFT")
  definitionJson Json
  lastRunAt      DateTime?
  lastStatus     String?
  createdById    String?
  createdAt      DateTime  @default(now())

  @@index([projectId, status])
}

enum AlertCategory {
  AVAILABILITY
  RELIABILITY
  PERFORMANCE
  SECURITY
  DEPENDENCY_CHANGE
}

enum AlertSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum BillingPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum CheckStatus {
  PASS
  FAIL
  WARN
}

enum CheckType {
  HTTP
  SSL
  KEYWORD
  RESPONSE_TIME
  HEARTBEAT_STALE
}

enum EventType {
  BOOKING_FAILED
  PAYMENT_FAILED
  WEBHOOK_FAILED
  EMAIL_FAILED
  AUTH_SPIKE
  CRON_MISSED
  GOOGLE_API_FAILED
  DEPLOYMENT_STARTED
  DEPLOYMENT_FINISHED
  SERVICE_DOWN
  HEARTBEAT_MISSED
  AUTH_FAILURE_SPIKE
  TRAFFIC_SPIKE
  WEBHOOK_SIGNATURE_FAILED
  DEPLOY_FAILED
  SSL_EXPIRING
  DOMAIN_EXPIRING
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MONITORING
  RESOLVED
}

enum IntegrationType {
  WEBHOOK
  EMAIL
  STRIPE
  WORKER_PROVIDER
  SERVICE_PROVIDER
  DEPLOYMENT_PROVIDER
  STATUS_PROVIDER
  RUNBOOK_PROVIDER
}

enum IntegrationValidationStatus {
  UNKNOWN
  VALID
  INVALID
}

enum ProjectStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  DOWN
  PAUSED
  MAINTENANCE
  RECOVERING
}

enum BillingPlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
  CUSTOM
}

enum BillingStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
  SUSPENDED
}

model ProjectBilling {
  id                 String          @id
  projectId          String          @unique
  plan               BillingPlanType @default(FREE)
  monthlyPrice       Float           @default(0)
  currency           String          @default("GBP")
  billingStatus      BillingStatus   @default(ACTIVE)
  billingStartDate   DateTime?
  renewalDate        DateTime?
  dataRetentionDays  Int             @default(30)
  checkLimit         Int?
  userLimit          Int?
  automationRunLimit Int?
  customLimits       Json?
  internalNotes      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime
  Project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum RemediationStatus {
  PENDING_APPROVAL
  APPROVED
  EXECUTING
  SUCCEEDED
  FAILED
  REJECTED
  MISSING_CONTEXT
  MISCONFIGURED_ENV
}

enum ServiceType {
  APP
  MODULE
  WORKFLOW
  COMPONENT
  FRONTEND
  API
  DATABASE
  WORKER
  WEBHOOK
  EMAIL
  PAYMENT
  THIRD_PARTY
}

enum MaintenanceWindowStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AutomationPlaybookVersionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  DEPRECATED
}

model MaintenanceWindow {
  id                 String                   @id
  organizationId     String
  projectId          String?
  name               String
  description        String?
  startsAt           DateTime
  endsAt             DateTime
  status             MaintenanceWindowStatus    @default(SCHEDULED)
  suppressAlerts     Boolean                  @default(true)
  suppressIncidents  Boolean                  @default(false)
  allowAutonomous    Boolean                  @default(false)
  createdById        String
  cancelledById      String?
  cancelledAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime
  Organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project            Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  Services           MaintenanceWindowService[]

  @@index([organizationId, startsAt])
  @@index([organizationId, status])
  @@index([projectId, startsAt])
}

model MaintenanceWindowService {
  id                  String            @id
  maintenanceWindowId String
  serviceId           String
  MaintenanceWindow   MaintenanceWindow @relation(fields: [maintenanceWindowId], references: [id], onDelete: Cascade)
  Service             Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([maintenanceWindowId, serviceId])
}

model IngestReplayNonce {
  nonce     String   @id
  route     String
  projectId String?
  apiKeyId  String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  UNPAID
  CANCELLED
  SUSPENDED
}

model Plan {
  id                   String           @id
  code                 String           @unique
  name                 String
  billingInterval      BillingInterval  @default(MONTHLY)
  monthlyPrice         Float
  annualPrice          Float?
  currency             String           @default("GBP")
  active               Boolean          @default(true)
  sortOrder            Int              @default(0)
  stripePriceMonthlyId String?
  stripePriceAnnualId  String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime
  PlanEntitlement      PlanEntitlement[]
  Subscription         Subscription[]
}

model PlanEntitlement {
  id            String  @id
  planId        String
  featureKey    String
  enabled       Boolean @default(true)
  limit         Int?
  retentionDays Int?
  configuration Json?
  Plan          Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model Subscription {
  id                   String             @id
  organizationId       String             @unique
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  Organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Plan                 Plan               @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model UsageRecord {
  id             String   @id
  organizationId String
  metricKey      String
  quantity       Int
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, metricKey, periodStart])
}

model IncidentMemoryEntry {
  id                String    @id
  organizationId    String
  incidentId        String    @unique
  title             String
  category          String?
  diagnosisSummary  String
  rootCause         String?
  resolutionSummary String?
  signatureText     String
  embeddingJson     Json?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  Organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, resolvedAt])
}

model StripeWebhookEvent {
  id            String   @id
  stripeEventId String   @unique
  eventType     String
  status        String
  error         String?
  processedAt   DateTime @default(now())

  @@index([eventType, processedAt])
}
