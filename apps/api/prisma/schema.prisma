generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Alert {
  id                    String          @id
  projectId             String
  serviceId             String?
  sourceType            String
  sourceId              String?
  severity              AlertSeverity
  title                 String
  message               String
  status                AlertStatus     @default(OPEN)
  firstSeenAt           DateTime        @default(now())
  lastSeenAt            DateTime        @default(now())
  acknowledgedAt        DateTime?
  resolvedAt            DateTime?
  assignedToUserId      String?
  category              AlertCategory   @default(AVAILABILITY)
  integrationId         String?
  maintenanceSuppressed Boolean         @default(false)
  maintenanceWindowId   String?
  /// Stable signal grouping key (source + service + title hash). Used for dedupe/flapping.
  fingerprint           String?
  /// How many times this open alert fingerprint has been observed.
  occurrenceCount       Int             @default(1)
  User                  User?           @relation(fields: [assignedToUserId], references: [id])
  Project               Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Service               Service?        @relation(fields: [serviceId], references: [id])
  IncidentAlert         IncidentAlert[]

  @@index([projectId, fingerprint, status])
}

model AuditLog {
  id           String   @id
  userId       String?
  action       String
  entityType   String
  entityId     String
  metadataJson Json?
  createdAt    DateTime @default(now())
  User         User?    @relation(fields: [userId], references: [id])
}

model AutoRemediationPolicy {
  id             String   @id
  organizationId String
  policyType     String
  policyKey      String
  enabled        Boolean  @default(false)
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@unique([organizationId, policyType, policyKey])
  @@index([organizationId])
}

model Check {
  id                 String        @id
  serviceId          String
  name               String
  type               CheckType
  intervalSeconds    Int
  timeoutMs          Int
  expectedStatusCode Int?
  expectedKeyword    String?
  failureThreshold   Int           @default(3)
  recoveryThreshold  Int           @default(2)
  configJson         Json?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime
  Service            Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  CheckResult        CheckResult[]
}

model CheckResult {
  id             String      @id
  checkId        String
  status         CheckStatus
  responseCode   Int?
  responseTimeMs Int?
  message        String?
  rawJson        Json?
  checkedAt      DateTime    @default(now())
  Check          Check       @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([checkId, checkedAt])
}

model Event {
  id          String        @id
  projectId   String
  serviceId   String?
  type        EventType
  severity    AlertSeverity
  source      String
  message     String
  fingerprint String?
  payloadJson Json?
  createdAt   DateTime      @default(now())
  Project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Service     Service?      @relation(fields: [serviceId], references: [id])

  @@index([projectId, createdAt])
}

model Heartbeat {
  id          String   @id
  projectId   String
  environment String
  appVersion  String?
  commitSha   String?
  status      String
  message     String?
  payloadJson Json?
  receivedAt  DateTime @default(now())
  Project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, receivedAt])
}

model Incident {
  id                    String                     @id
  projectId             String
  correlationGroupId    String?
  title                 String
  severity              AlertSeverity
  status                IncidentStatus             @default(OPEN)
  openedAt              DateTime                   @default(now())
  acknowledgedAt        DateTime?
  resolvedAt            DateTime?
  rootCause             String?
  resolutionNotes       String?
  /// Fingerprint for reopen/cooldown matching across alert groups.
  fingerprint           String?
  /// When this incident was merged into another (soft merge).
  mergedIntoIncidentId  String?
  reopenCount           Int                        @default(0)
  lastReopenedAt        DateTime?
  ChangeEvent           ChangeEvent[]
  ChangeLedgerEntry     ChangeLedgerEntry[]
  IncidentTimelineEvent IncidentTimelineEvent[]
  Project               Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  IncidentAlert         IncidentAlert[]
  CorrelationGroup      OrganizationIncidentGroup? @relation(fields: [correlationGroupId], references: [id], onDelete: SetNull)
  MergedInto            Incident?                  @relation("IncidentMerge", fields: [mergedIntoIncidentId], references: [id], onDelete: SetNull)
  MergedFrom            Incident[]                 @relation("IncidentMerge")

  @@index([projectId, openedAt])
  @@index([correlationGroupId])
  @@index([projectId, fingerprint])
  @@index([mergedIntoIncidentId])
}

model IncidentAlert {
  incidentId String
  alertId    String
  Alert      Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  Incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@id([incidentId, alertId])
}

model NotificationChannel {
  id        String   @id
  type      String
  name      String
  target    String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  projectId String?
  updatedAt DateTime
  Project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, isActive])
}

model OnboardingProgress {
  id             String       @id
  organizationId String       @unique
  completedSteps String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrgApiKey {
  id                String       @id
  organizationId    String
  name              String
  keyId             String       @unique
  secretHash        String
  scopes            Json
  environment       String
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime     @default(now())
  projectId         String?
  revokedAt         DateTime?
  lastUsedRoute     String?
  lastUsedIp        String?
  lastUsedUserAgent String?
  revokeReason      String?
  Organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, revokedAt])
  @@index([projectId])
}

model Organization {
  id                       String                      @id
  name                     String
  slug                     String                      @unique
  plan                     BillingPlan                 @default(FREE)
  topologyMode             String                      @default("CENTRALISED")
  isActive                 Boolean                     @default(true)
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime
  OnboardingProgress       OnboardingProgress?
  OrgApiKey                OrgApiKey[]
  Project                  Project[]
  StatusPage               StatusPage[]
  User                     User[]
  IncidentGroups           OrganizationIncidentGroup[]
  MaintenanceWindows       MaintenanceWindow[]
  Subscription             Subscription?
  UsageRecord              UsageRecord[]
  IncidentMemoryEntry      IncidentMemoryEntry[]
  OperationalObservation   OperationalObservation[]
  LearningBaseline         LearningBaseline[]
  OperationalPattern       OperationalPattern[]
  AiConfidenceRecord       AiConfidenceRecord[]
  PredictionCandidate      PredictionCandidate[]
  PredictionAccuracyLog    PredictionAccuracyLog[]
  OperationsTimelineEvent  OperationsTimelineEvent[]
  DeploymentRecord         DeploymentRecord[]
  AiDecisionAudit          AiDecisionAudit[]
  ApplicationLearningModel ApplicationLearningModel[]
  RetentionPolicy          RetentionPolicy[]
  Connection               Connection[]
  ChangeLedgerEntry        ChangeLedgerEntry[]
  OperationalLocation      OperationalLocation[]
  OperationalEntity        OperationalEntity[]
  OperationalRelationship  OperationalRelationship[]
}

model OrganizationIncidentGroup {
  id                String       @id
  organizationId    String
  correlationKey    String
  rootCauseSummary  String?
  primaryIncidentId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  Organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Incidents         Incident[]

  @@index([organizationId, correlationKey])
  @@index([organizationId, createdAt])
}

model Project {
  id                      String                    @id
  name                    String
  slug                    String                    @unique
  clientName              String
  description             String?
  environment             String
  status                  ProjectStatus             @default(UNKNOWN)
  healthReason            String?
  healthSource            String?
  lastCompletedCheckAt    DateTime?
  lastSignalAt            DateTime?
  monitoringEnabled       Boolean                   @default(true)
  monitoringStartedAt     DateTime?
  automationMode          String                    @default("OBSERVE")
  /// Emergency kill-switch: blocks all remediator-driven repair execution for this project.
  remediationEmergencyDisabled Boolean              @default(false)
  projectOwner            String?
  operationalContact      String?
  defaultRegion           String?
  frontendUrl             String?
  backendUrl              String?
  repoUrl                 String?
  vercelProjectId         String?
  renderServiceId         String?
  apiKey                  String                    @unique
  signingSecret           String
  maintenanceTier         String?
  isActive                Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  organizationId          String?
  Alert                   Alert[]
  ChangeEvent             ChangeEvent[]
  Event                   Event[]
  Heartbeat               Heartbeat[]
  Incident                Incident[]
  IncidentTimelineEvent   IncidentTimelineEvent[]
  NotificationChannel     NotificationChannel[]
  Organization            Organization?             @relation(fields: [organizationId], references: [id])
  ProjectIntegration      ProjectIntegration[]
  ServiceDependency       ServiceDependency[]
  Service                 Service[]
  SLODefinition           SLODefinition[]
  SLOWindow               SLOWindow[]
  StatusPage              StatusPage[]
  MaintenanceWindows      MaintenanceWindow[]
  ProjectBilling          ProjectBilling?
  Connection              Connection[]
  ChangeLedgerEntry       ChangeLedgerEntry[]
  OperationalEntity       OperationalEntity[]
  OperationalLocation     OperationalLocation?      @relation(fields: [operationalLocationId], references: [id], onDelete: SetNull)
  operationalLocationId   String?
  OperationalRelationship OperationalRelationship[]

  @@index([organizationId])
  @@index([operationalLocationId])
}

/// A generic, organization-scoped operational connection. Secret material is
/// referenced through secretRef; configurationJson must never contain secrets.
model Connection {
  id                   String              @id
  organizationId       String
  projectId            String?
  name                 String
  type                 String
  mode                 String
  environment          String              @default("production")
  authMethod           String              @default("NONE")
  capabilitiesJson     Json?
  configurationJson    Json?
  secretRef            String?
  health               String              @default("UNKNOWN")
  healthReason         String?
  lastSuccessAt        DateTime?
  lastFailureAt        DateTime?
  lastError            String?
  requestRatePerMinute Int?
  errorRatePercent     Float?
  permissionsJson      Json?
  installationStatus   String              @default("PENDING")
  collectorVersion     String?
  manifestVersion      String              @default("1.0")
  deactivatedAt        DateTime?
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime
  Organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project              Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ChangeLedgerEntry    ChangeLedgerEntry[]

  @@unique([organizationId, projectId, name])
  @@index([organizationId, isActive, createdAt])
  @@index([projectId, isActive])
  @@index([organizationId, mode, installationStatus])
}

/// Optional location hierarchy for centrally managed, distributed, or hybrid organizations.
model OperationalLocation {
  id                String                @id
  organizationId    String
  parentLocationId  String?
  name              String
  type              String                @default("SITE")
  topologyMode      String?
  regionCode        String?
  addressJson       Json?
  metadataJson      Json?
  lifecycle         String                @default("ACTIVE")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime
  Organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Parent            OperationalLocation?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: SetNull)
  Children          OperationalLocation[] @relation("LocationHierarchy")
  Project           Project[]
  OperationalEntity OperationalEntity[]

  @@unique([organizationId, parentLocationId, name])
  @@index([organizationId, type])
  @@index([organizationId, regionCode])
}

/// Flexible graph node. entityType intentionally remains a string so product
/// capabilities are not constrained by a brittle platform enum.
model OperationalEntity {
  id                    String                    @id
  organizationId        String
  projectId             String?
  operationalLocationId String?
  legacyServiceId       String?                   @unique
  entityType            String
  name                  String
  externalId            String?
  criticality           String                    @default("MEDIUM")
  health                String                    @default("UNKNOWN")
  healthOverride        String?
  healthReason          String?
  healthConfidence      Float?
  provenance            String                    @default("DECLARED")
  discoverySource       String?
  discoveredAt          DateTime?
  lastSeenAt            DateTime?
  tagsJson              Json?
  metadataJson          Json?
  lifecycle             String                    @default("ACTIVE")
  /// Phase 7 ownership / routing on graph entities
  ownerUserId           String?
  ownerTeam             String?
  runbookUrl            String?
  escalationContact     String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime
  Organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project               Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  OperationalLocation   OperationalLocation?      @relation(fields: [operationalLocationId], references: [id], onDelete: SetNull)
  LegacyService         Service?                  @relation(fields: [legacyServiceId], references: [id], onDelete: SetNull)
  OwnerUser             User?                     @relation("OperationalEntityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  OutgoingRelationships OperationalRelationship[] @relation("OperationalRelationshipSource")
  IncomingRelationships OperationalRelationship[] @relation("OperationalRelationshipTarget")

  @@unique([organizationId, entityType, externalId])
  @@index([organizationId, projectId, entityType])
  @@index([organizationId, operationalLocationId, health])
  @@index([organizationId, provenance, lifecycle])
  @@index([organizationId, ownerUserId])
}

/// Flexible graph edge. LEARNED relationships must be created as pending and
/// explicitly approved before they become active topology.
model OperationalRelationship {
  id               String            @id
  organizationId   String
  projectId        String?
  sourceEntityId   String
  targetEntityId   String
  relationshipType String
  provenance       String            @default("DECLARED")
  approvalStatus   String            @default("APPROVED")
  requiresApproval Boolean           @default(false)
  /// REQUIRED | OPTIONAL | REDUNDANT | DEGRADED | BUSINESS_CRITICAL
  impactRole       String            @default("REQUIRED")
  observationCount Int               @default(0)
  criticality      String            @default("MEDIUM")
  confidence       Float?
  evidenceJson     Json?
  discoveredAt     DateTime?
  lastObservedAt   DateTime?
  lifecycle        String            @default("ACTIVE")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  Organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  Source           OperationalEntity @relation("OperationalRelationshipSource", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  Target           OperationalEntity @relation("OperationalRelationshipTarget", fields: [targetEntityId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sourceEntityId, targetEntityId, relationshipType])
  @@index([organizationId, projectId, approvalStatus])
  @@index([sourceEntityId, lifecycle])
  @@index([targetEntityId, lifecycle])
}

model ProjectIntegration {
  id                String                      @id
  projectId         String
  type              IntegrationType
  name              String?
  enabled           Boolean                     @default(true)
  configJson        Json?
  secretRef         String?
  validationStatus  IntegrationValidationStatus @default(UNKNOWN)
  validationMessage String?
  validationDetails Json?
  lastValidatedAt   DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime
  Project           Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([projectId, enabled])
}

model PlatformStripeSettings {
  id                      String                      @id
  secretKeyCiphertext     String?
  secretKeyIv             String?
  secretKeyAuthTag        String?
  webhookSecretCiphertext String?
  webhookSecretIv         String?
  webhookSecretAuthTag    String?
  publishableKey          String?
  stripeAccountId         String?
  apiBase                 String                      @default("https://api.stripe.com")
  mode                    String?
  validationStatus        IntegrationValidationStatus @default(UNKNOWN)
  validationMessage       String?
  validationDetails       Json?
  lastValidatedAt         DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime
}

model RemediationLog {
  id                  String            @id
  organizationId      String
  alertId             String?
  incidentId          String?
  action              String
  contextJson         Json?
  executedBy          String?
  status              RemediationStatus @default(PENDING_APPROVAL)
  resultJson          Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime
  approvedBy          String?
  executedAt          DateTime?
  projectId           String?
  serviceId           String?
  impactTier          String?
  predictedLabel      String?
  predictedScore      Int?
  executionMode       String            @default("MANUAL")
  policySnapshot      Json?
  suppressionSnapshot Json?
  idempotencyKey      String?

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, action, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, executionMode, createdAt])
  @@index([incidentId, status, createdAt])
}

model RemediationLock {
  id             String   @id
  lockKey        String   @unique
  organizationId String
  incidentId     String?
  action         String?
  holder         String
  acquiredAt     DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
  @@index([organizationId, incidentId])
}

/// Outbound remediator repair attempt — signed request lifecycle + post-action verification.
model RemediatorRepairAttempt {
  id                   String                  @id
  organizationId       String
  projectId            String
  incidentId           String?
  alertId              String?
  providerType         IntegrationType
  remediatorAction     String
  target               String?
  reason               String?
  idempotencyKey       String
  nonce                String
  requestTimestamp     DateTime
  status               RemediatorRepairStatus  @default(REQUESTED)
  httpStatus           Int?
  requestPayloadJson   Json?
  responsePayloadJson  Json?
  verificationJson     Json?
  failureReason        String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime
  completedAt          DateTime?

  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, nonce])
  @@index([projectId, status, createdAt])
  @@index([organizationId, remediatorAction, createdAt])
  @@index([incidentId, createdAt])
}

enum RemediatorRepairStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  RUNNING
  COMPLETED
  FAILED
  TIMED_OUT
  VERIFICATION_FAILED
}

model AutomationPlaybook {
  id          String                      @id
  key         String                      @unique
  name        String
  description String
  riskLevel   String                      @default("LOW")
  isActive    Boolean                     @default(true)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime
  Versions    AutomationPlaybookVersion[]
}

model AutomationPlaybookVersion {
  id             String                          @id
  playbookId     String
  version        Int
  definitionJson Json?
  status         AutomationPlaybookVersionStatus @default(DRAFT)
  submittedById  String?
  submittedAt    DateTime?
  reviewedById   String?
  reviewedAt     DateTime?
  reviewReason   String?
  approvedAt     DateTime?
  deprecatedAt   DateTime?
  publishedAt    DateTime                        @default(now())
  publishedBy    String?
  Playbook       AutomationPlaybook              @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  Steps          AutomationPlaybookStep[]
  Runs           AutomationRun[]

  @@unique([playbookId, version])
  @@index([playbookId, status])
}

model AutomationPlaybookStep {
  id               String                    @id
  versionId        String
  stepOrder        Int
  action           String
  targetServiceKey String?
  approvalRequired Boolean                   @default(false)
  description      String
  Version          AutomationPlaybookVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, stepOrder])
}

model AutomationRun {
  id                 String                    @id
  organizationId     String
  projectId          String
  incidentId         String
  versionId          String
  approvedVersionId  String?
  executionMode      String                    @default("OBSERVE")
  status             String                    @default("PLANNED")
  planJson           Json
  analysisMode       String?
  confidence         Float?
  riskLevel          String?
  reason             String?
  /// Trigger that started the run (ALERT, INCIDENT, MANUAL, SCHEDULE, POLICY).
  triggerType        String?
  durationMs         Int?
  verificationStatus String?
  verifiedAt         DateTime?
  affectedServiceIds Json?
  createdBy          String?
  approvedBy         String?
  approvedAt         DateTime?
  cancelledBy        String?
  cancelledAt        DateTime?
  currentStepOrder   Int?
  supersededByRunId  String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime
  Version            AutomationPlaybookVersion @relation(fields: [versionId], references: [id])
  Steps              AutomationRunStep[]
  Approvals          AutomationApproval[]
  Outcomes           AutomationOutcome[]

  @@index([organizationId, incidentId, createdAt])
  @@index([projectId, status])
  @@index([organizationId, createdAt])
}

model AutomationRunStep {
  id               String        @id
  runId            String
  stepOrder        Int
  action           String
  targetServiceId  String?
  approvalRequired Boolean       @default(false)
  status           String        @default("PENDING")
  remediationLogId String?
  resultJson       Json?
  Run              AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepOrder])
}

model AutomationApproval {
  id         String        @id
  runId      String
  approvedBy String?
  reason     String
  decision   String
  scope      String        @default("RUN")
  createdAt  DateTime      @default(now())
  Run        AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AutomationPolicy {
  id             String   @id
  organizationId String
  policyKey      String
  enabled        Boolean  @default(false)
  executionMode  String   @default("OBSERVE")
  updatedBy      String?
  updatedAt      DateTime
  createdAt      DateTime @default(now())

  @@unique([organizationId, policyKey])
}

model AutomationOutcome {
  id          String        @id
  runId       String
  summary     String
  success     Boolean
  detailsJson Json?
  createdAt   DateTime      @default(now())
  Run         AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Service {
  id                        String                     @id
  projectId                 String
  name                      String
  type                      ServiceType
  status                    ProjectStatus              @default(UNKNOWN)
  criticality               String                     @default("MEDIUM")
  baseUrl                   String?
  isCritical                Boolean                    @default(false)
  /// Phase 7 ownership / routing
  ownerUserId               String?
  ownerTeam                 String?
  runbookUrl                String?
  escalationContact         String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime
  Alert                     Alert[]
  Check                     Check[]
  ChangeEvent               ChangeEvent[]
  Event                     Event[]
  IncomingDependencies      ServiceDependency[]        @relation("DependencyToService")
  OutgoingDependencies      ServiceDependency[]        @relation("DependencyFromService")
  Project                   Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  SLODefinition             SLODefinition[]
  MaintenanceWindowServices MaintenanceWindowService[]
  OperationalEntity         OperationalEntity?
  ChangeLedgerEntry         ChangeLedgerEntry[]
  OwnerUser                 User?                      @relation("ServiceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([projectId, ownerUserId])
  @@index([projectId, ownerTeam])
}

model ChangeEvent {
  id             String    @id
  organizationId String
  projectId      String?
  serviceId      String?
  incidentId     String?
  eventType      String
  actor          String?
  summary        String
  detailsJson    Json?
  occurredAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  Incident       Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  Project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  Service        Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([serviceId, occurredAt])
  @@index([incidentId, occurredAt])
}

/// Organization-scoped, factual ledger of operational changes. Evidence is
/// supplied by the caller or connector; this table never synthesizes events.
model ChangeLedgerEntry {
  id             String       @id
  organizationId String
  projectId      String?
  serviceId      String?
  incidentId     String?
  connectionId   String?
  kind           String
  summary        String
  actorType      String?
  actor          String?
  source         String
  externalId     String?
  evidenceJson   Json?
  occurredAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  Service        Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  Incident       Incident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  Connection     Connection?  @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([organizationId, kind, occurredAt])
  @@index([projectId, occurredAt])
  @@index([connectionId, occurredAt])
  @@index([organizationId, source, externalId])
}

model ServiceDependency {
  id               String    @id
  projectId        String
  fromServiceId    String
  toServiceId      String
  dependencyType   String    @default("RUNTIME")
  criticality      String    @default("HIGH")
  isActive         Boolean   @default(true)
  /// Telemetry-backed evidence count; 0 means declared without observed confirmation.
  evidenceCount    Int       @default(0)
  /// 0..1 strength derived from observed co-occurrence / failures; not invented edges.
  evidenceStrength Float     @default(0)
  lastObservedAt   DateTime?
  source           String    @default("MANUAL")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  FromService      Service   @relation("DependencyFromService", fields: [fromServiceId], references: [id], onDelete: Cascade)
  Project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ToService        Service   @relation("DependencyToService", fields: [toServiceId], references: [id], onDelete: Cascade)

  @@unique([fromServiceId, toServiceId, dependencyType])
  @@index([projectId, isActive])
  @@index([fromServiceId])
  @@index([toServiceId])
}

model IncidentTimelineEvent {
  id          String         @id
  incidentId  String
  projectId   String
  eventType   String
  summary     String
  sourceType  String?
  sourceId    String?
  severity    AlertSeverity?
  payloadJson Json?
  occurredAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())
  Incident    Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  Project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([incidentId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([sourceType, sourceId])
}

model SLODefinition {
