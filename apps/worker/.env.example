DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opswatch?schema=public"
OPSWATCH_API_URL="http://127.0.0.1:4000/api"
WORKER_INTERNAL_SECRET="opswatch-local-worker-secret"
OPSWATCH_SELF_MONITOR_SLUG="opswatch-production"
OPSWATCH_HEARTBEAT_API_KEY=""
OPSWATCH_HEARTBEAT_SIGNING_SECRET=""
OPSWATCH_HEARTBEAT_INTERVAL_MS="60000"
OPSWATCH_ENVIRONMENT="production"
# Production default: keep worker auto-heal disabled until policy is enabled.
WORKER_AUTO_HEAL_ENABLED="false"
WORKER_AUTO_HEAL_INTERVAL_MS="180000"
WORKER_AUTOMATION_AUTONOMOUS_ENABLED="false"
WORKER_AUTOMATION_AUTONOMOUS_INTERVAL_MS="300000"
# Data-lifecycle retention pruning (enabled by default; set to "false" to disable).
WORKER_RETENTION_ENABLED="true"
WORKER_RETENTION_INTERVAL_MS="21600000"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="alerts@opswatch.app"
