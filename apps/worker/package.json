{
	"name": "@opswatch/worker",
	"version": "0.1.0",
	"private": true,
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./jobs": "./dist/jobs/index.js"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"lint": "eslint \"src/**/*.ts\"",
		"test": "vitest run --config vitest.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@opswatch/api": "workspace:*",
		"@opswatch/shared": "workspace:*",
		"@prisma/client": "^5.21.1"
		,
		"dotenv": "^16.4.5",
		"nodemailer": "^6.10.0"
	},
	"devDependencies": {
		"@types/node": "^22.7.4",
		"tsx": "^4.19.1",
		"typescript": "^5.6.3",
		"vitest": "^4.1.5"
	}
}
